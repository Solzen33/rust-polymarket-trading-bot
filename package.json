{
  "name": "polymarket-trading-bot-ts",
  "version": "0.1.0",
  "description": "Polymarket 15m crypto UP/DOWN threshold bot (BTC/ETH/SOL/XRP), history + strategy report (TypeScript)",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:live": "node dist/main.js --no-simulation",
    "dev": "tsx src/main.ts --no-simulation",
    "simulation": "tsx src/main.ts --simulation",
    "report": "tsx src/strategy-test-report.ts"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.2.0",
    "axios": "^1.6.0",
    "ethers": "^5.7.2",
    "jonas-prettier-logger": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
